10 REM MACHIN PI CALCULATION IN BASIC
20 TERMS = 10000
30 PI = 0

40 REM ---- ARCTAN(1/5) ----
50 X = 1/5
60 S = 0
70 P = X
80 SIGN = 1
90 FOR N = 0 TO TERMS
100   TERM = P / (2*N + 1)
110   S = S + SIGN * TERM
120   P = P * X * X
130   SIGN = -SIGN
140 NEXT N
150 ATAN5 = S

160 REM ---- ARCTAN(1/239) ----
170 X = 1/239
180 S = 0
190 P = X
200 SIGN = 1
210 FOR N = 0 TO TERMS
220   TERM = P / (2*N + 1)
230   S = S + SIGN * TERM
240   P = P * X * X
250   SIGN = -SIGN
260 NEXT N
270 ATAN239 = S

280 PI = 4 * (4 * ATAN5 - ATAN239)

290 PRINT "PI APPROX = "; PI
300 END

