10 CLS
20 RANDOMIZE TIMER
30 SHIELDS = 100
40 AMMO = 20
50 SCORE = 0
60 WAVE = 1
70 ALIENS = 0
80 FUEL = 50
90 TORPEDOES = 3
100 STARDATE = INT(RND*9000)+1000
110 COLOR 10,0
120 PRINT ""
130 PRINT "  ************************************"
140 PRINT "  *                                  *"
150 PRINT "  *       A L I E N                  *"
160 PRINT "  *     I N V A S I O N              *"
170 PRINT "  *                                  *"
180 PRINT "  *   EARTH DEFENSE FORCE  ALPHA-7   *"
190 PRINT "  *                                  *"
200 PRINT "  ************************************"
210 COLOR 7,0
220 PRINT ""
230 PRINT "  STARDATE: "; STARDATE
240 PRINT ""
250 PRINT "  COMMANDER! THE XELTHARI ARMADA HAS"
260 PRINT "  ENTERED OUR SOLAR SYSTEM. YOU ARE"
270 PRINT "  THE LAST HOPE FOR PLANET EARTH."
280 PRINT ""
290 COLOR 14,0
300 PRINT "  PRESS ANY KEY TO BEGIN..."
