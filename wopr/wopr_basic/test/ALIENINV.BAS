430 PRINT "  APPROACHING EARTH ORBIT!"
440 PRINT ""
450 FOR I = 1 TO ALIENS
460 PRINT "  [ALIEN "; I; "] STATUS: HOSTILE"
470 NEXT I
480 PRINT ""
490 PRINT "------------------------------------"
500 PRINT "  SHIELDS: "; SHIELDS; "%  |  AMMO: "; AMMO; "  |  TORPS: "; TORPEDOES
510 PRINT "  FUEL:    "; FUEL; "%  |  SCORE: "; SCORE; "  |  ALIENS: "; ALIENS
520 PRINT "------------------------------------"
530 PRINT ""
540 PRINT "  ACTIONS:"
550 PRINT "  [1] FIRE LASER CANNON    (uses 1 ammo)"
560 PRINT "  [2] LAUNCH TORPEDO       (uses 1 torpedo)"
570 PRINT "  [3] EVASIVE MANEUVER     (uses 10 fuel)"
580 PRINT "  [4] BOOST SHIELDS        (uses 5 fuel)"
590 PRINT "  [5] SCAN ENEMY FLEET"
600 PRINT "  [6] EMERGENCY RETREAT"
610 PRINT ""
620 COLOR 14,0
630 INPUT "  YOUR COMMAND, COMMANDER: ", CMD
640 COLOR 7,0
650 PRINT ""
660 IF CMD = 1 THEN GOTO 710
670 IF CMD = 2 THEN GOTO 770
680 IF CMD = 3 THEN GOTO 840
690 IF CMD = 4 THEN GOTO 910
695 IF CMD = 5 THEN GOTO 970
697 IF CMD = 6 THEN GOTO 1040
699 COLOR 12,0: PRINT "  UNKNOWN COMMAND!": COLOR 7,0: GOTO 1080
710 IF AMMO <= 0 THEN SOUND 200,5: PRINT "  NO AMMO REMAINING!": GOTO 1080
720 AMMO = AMMO - 1
730 HIT = INT(RND * 100)
740 IF HIT >= 70 THEN SOUND 300,2: SOUND 250,2: SOUND 200,4: COLOR 12,0: PRINT "  LASER MISSES!": COLOR 7,0: GOTO 1080
750 SOUND 880,2: SOUND 1047,2: SOUND 1319,4
760 COLOR 10,0: PRINT "  DIRECT HIT! WARSHIP DESTROYED!": COLOR 7,0
762 ALIENS = ALIENS - 1
764 SCORE = SCORE + 100
766 GOTO 1080
770 IF TORPEDOES <= 0 THEN SOUND 200,5: PRINT "  NO TORPEDOES LEFT!": GOTO 1080
780 TORPEDOES = TORPEDOES - 1
790 SOUND 110,3: SOUND 98,3: SOUND 82,3: SOUND 65,9
800 COLOR 10,0: PRINT "  QUANTUM TORPEDO LAUNCHED!": COLOR 7,0
810 PRINT "  SHOCKWAVE RIPPLES THROUGH ENEMY FLEET!"
820 DMG = 1 + INT(RND * 3)
822 IF DMG > ALIENS THEN DMG = ALIENS
824 ALIENS = ALIENS - DMG
826 SCORE = SCORE + (DMG * 150)
828 PRINT "  "; DMG; " ENEMY SHIPS DESTROYED!"
830 GOTO 1080
840 IF FUEL < 10 THEN SOUND 200,5: PRINT "  NOT ENOUGH FUEL!": GOTO 1080
850 FUEL = FUEL - 10
860 EVADE = INT(RND * 100)
870 IF EVADE < 60 THEN SOUND 440,2: SOUND 550,2: SOUND 660,4: COLOR 10,0: PRINT "  MANEUVER SUCCESSFUL!": COLOR 7,0: GOTO 490
880 SOUND 330,2: SOUND 280,4
890 COLOR 12,0: PRINT "  PARTIAL EVASION - GLANCING BLOW!": COLOR 7,0
900 SHIELDS = SHIELDS - 10: GOTO 490
910 IF FUEL < 5 THEN SOUND 200,5: PRINT "  NOT ENOUGH FUEL!": GOTO 1080
920 FUEL = FUEL - 5
930 SHIELDS = SHIELDS + 20
940 IF SHIELDS > 100 THEN SHIELDS = 100
950 SOUND 523,2: SOUND 659,2: SOUND 784,2: SOUND 1047,4
960 COLOR 10,0: PRINT "  SHIELD CAPACITORS RECHARGED!": COLOR 7,0: GOTO 1080
970 SOUND 700,1: SOUND 900,1: SOUND 700,1
980 COLOR 11,0: PRINT "  === TACTICAL SCAN ===": COLOR 7,0
990 PRINT "  REMAINING HOSTILES:    "; ALIENS
995 PRINT "  ENEMY SHIELD STRENGTH: "; INT(RND*80)+20; "%"
996 PRINT "  ENEMY WEAPON CHARGE:   "; INT(RND*100); "%"
997 PRINT "  FLAGSHIP DETECTED:     ";
998 IF INT(RND*2) = 1 THEN PRINT "YES (+500 BONUS)" ELSE PRINT "NO"
999 GOTO 1080
1040 CLS
1042 SOUND 220,3: SOUND 196,3: SOUND 165,9
1044 COLOR 12,0
1046 PRINT ""
1048 PRINT "  COWARDLY RETREAT INITIATED..."
1050 PRINT "  YOUR SHIP JUMPS TO HYPERSPACE."
1052 PRINT "  EARTH IS LEFT UNDEFENDED."
1054 COLOR 7,0
1056 SCORE = SCORE - 500
1058 IF SCORE < 0 THEN SCORE = 0
1060 GOTO 1700
1080 IF ALIENS <= 0 THEN GOTO 1400
1090 PRINT ""
1092 SOUND 165,2: SOUND 147,2: SOUND 131,2: SOUND 110,2
1094 COLOR 12,0: PRINT "  *** XELTHARI COUNTER-ATTACK! ***": COLOR 7,0
1096 ATKS = 1 + INT(ALIENS / 3)
1098 FOR A = 1 TO ATKS
1100 ROLL = INT(RND * 100)
1102 IF ROLL < 55 THEN SOUND 180,3: SOUND 150,5: PRINT "  ALIEN BEAM HITS! -15 SHIELDS": SHIELDS = SHIELDS - 15
1104 IF ROLL >= 55 THEN SOUND 440,1: PRINT "  ALIEN SHOT MISSES YOUR HULL!"
1106 NEXT A
1108 PRINT ""
1110 IF SHIELDS <= 0 THEN GOTO 1550
1112 IF AMMO <= 0 AND TORPEDOES <= 0 THEN COLOR 12,0: PRINT "  WARNING: ALL WEAPONS DEPLETED!": COLOR 7,0
1114 IF FUEL <= 0 THEN COLOR 12,0: PRINT "  WARNING: FUEL CRITICAL!": COLOR 7,0
1116 IF ALIENS <= 0 THEN GOTO 1400
1118 GOTO 490
1400 CLS
1402 SOUND 523,3: SOUND 659,3: SOUND 784,3: SOUND 1047,3: SOUND 1319,9
1404 COLOR 10,0
1406 PRINT ""
1408 PRINT "  *** WAVE "; WAVE; " CLEARED! ***"
1410 COLOR 7,0
1412 PRINT ""
1414 PRINT "  THE XELTHARI FLEET IN THIS SECTOR IS DESTROYED!"
1416 PRINT "  EARTH BREATHES A TEMPORARY SIGH OF RELIEF."
1418 PRINT ""
1420 WAVE = WAVE + 1
1422 SCORE = SCORE + (WAVE * 200)
1424 AMMO = AMMO + 10
1426 IF AMMO > 30 THEN AMMO = 30
1428 TORPEDOES = TORPEDOES + 1
1430 IF TORPEDOES > 5 THEN TORPEDOES = 5
1432 FUEL = FUEL + 20
1434 IF FUEL > 100 THEN FUEL = 100
1436 PRINT "  SUPPLY POD: +10 AMMO, +1 TORPEDO, +20 FUEL"
1438 PRINT ""
1440 IF WAVE > 6 THEN GOTO 1620
1442 COLOR 14,0
1444 INPUT "  CONTINUE TO NEXT WAVE? (Y/N): ", C$
1446 COLOR 7,0
1448 IF C$ = "Y" OR C$ = "y" THEN CLS: GOTO 350
1450 GOTO 1700
1550 CLS
1552 SOUND 220,4: SOUND 196,4: SOUND 175,4: SOUND 147,12
1554 COLOR 12,0
1556 PRINT ""
1558 PRINT "  ************************************"
1560 PRINT "  *                                  *"
1562 PRINT "  *  SHIELDS DEPLETED -- HULL BREACH *"
1564 PRINT "  *                                  *"
1566 PRINT "  *  YOUR SHIP HAS BEEN DESTROYED.   *"
1568 PRINT "  *  EARTH FALLS TO THE XELTHARI.    *"
1570 PRINT "  *                                  *"
1572 PRINT "  ************************************"
1574 COLOR 7,0
1576 GOTO 1700
1620 CLS
1622 SOUND 784,3: SOUND 880,3: SOUND 988,3: SOUND 1047,9
1624 COLOR 14,0
1626 PRINT ""
1628 PRINT "  ************************************"
1630 PRINT "  *                                  *"
1632 PRINT "  *   XELTHARI ARMADA DEFEATED!      *"
1634 PRINT "  *                                  *"
1636 PRINT "  *   YOU HAVE SAVED PLANET EARTH!   *"
1638 PRINT "  *   A MONUMENT WILL BE BUILT IN    *"
1640 PRINT "  *   YOUR HONOR, COMMANDER.         *"
1642 PRINT "  *                                  *"
1644 PRINT "  ************************************"
1646 COLOR 7,0
1700 PRINT ""
1702 PRINT "  FINAL SCORE:      "; SCORE
1704 PRINT "  WAVES COMPLETED:  "; WAVE - 1
