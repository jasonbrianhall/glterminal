674 RETURN

680 REM Test: Comparison operators
681 TESTOK = 0
682 IF (5 > 3) AND (2 < 4) AND (7 >= 7) AND (3 <= 5) AND (1 <> 2) THEN TESTOK = 1
683 RETURN

690 REM Test: STR$
691 TESTOK = 0
