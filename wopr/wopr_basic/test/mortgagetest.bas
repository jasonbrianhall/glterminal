643 PF = 500
644 AMORT(0, 1) = AF
645 AMORT(1, 2) = 400
646 AMORT(1, 1) = AMORT(0, 1) - PF + AMORT(1, 2)
647 IF AMORT(1, 1) = 99900 THEN TESTOK = 1
648 RETURN

650 REM Test: Float arithmetic
