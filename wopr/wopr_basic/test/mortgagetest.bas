1 REM === COMPREHENSIVE TEST SUITE FOR MORTGAGE.BAS COMMANDS ===
2 REM Tests: GOSUB, RETURN, GOTO, IF, DIM, CHAIN, INKEY$, COLOR, CLS, 
3 REM LOCATE, PRINT, USING, INPUT, LINE INPUT, STRING$, CHR$, VAL,
4 REM MID$, ASC, INT, PEEK, SPC, STR$, FOR, NEXT, SCREEN, KEY OFF, WIDTH

10 FAILED = 0 : PASSED = 0
20 PRINT "===== MORTGAGE.BAS COMMAND TEST SUITE ====="
30 PRINT ""

40 REM Test 1: REM statement
50 GOSUB 5000
60 IF TESTOK THEN PRINT "PASS: REM statement" ELSE PRINT "FAIL: REM statement" : FAILED = FAILED + 1

70 REM Test 2: GOTO statement
80 GOSUB 5100
90 IF TESTOK THEN PRINT "PASS: GOTO statement" ELSE PRINT "FAIL: GOTO statement" : FAILED = FAILED + 1

