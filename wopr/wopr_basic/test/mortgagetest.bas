520 REM Test 20: STR$ function
521 GOSUB 690
522 IF TESTOK THEN PRINT "PASS: STR$ function" ELSE PRINT "FAIL: STR$" : FAILED = FAILED + 1

523 PRINT ""
524 PRINT "===== TEST RESULTS ====="
525 PASSED = 20 - FAILED
526 PRINT "PASSED: "; PASSED
527 PRINT "FAILED: "; FAILED
528 END

500 REM Test: REM (ignored by parser)
501 TESTOK = 1
502 RETURN

510 REM Test: GOTO
511 TESTOK = 0
512 GOTO 513
513 TESTOK = 1
514 RETURN

520 REM Test: GOSUB/RETURN
521 TESTOK = 0
522 GOSUB 523
523 RETURN
524 TESTOK = 1
525 RETURN

530 REM Test: IF
531 TESTOK = 0
532 IF 5 > 3 THEN TESTOK = 1
533 RETURN

540 REM Test: String assignment
541 TESTOK = 0
542 A$ = "HELLO"
543 IF A$ = "HELLO" THEN TESTOK = 1
544 RETURN

550 REM Test: DIM
