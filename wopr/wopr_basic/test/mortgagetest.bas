580 REM Test 19: Scientific notation
590 GOSUB 6800
600 IF TESTOK THEN PRINT "PASS: Scientific notation" ELSE PRINT "FAIL: Scientific notation" : FAILED = FAILED + 1

610 REM Test 20: Hex numbers
620 GOSUB 6900
630 IF TESTOK THEN PRINT "PASS: Hex numbers" ELSE PRINT "FAIL: Hex numbers" : FAILED = FAILED + 1

640 REM Test 21: Float arithmetic
650 GOSUB 7000
660 IF TESTOK THEN PRINT "PASS: Float arithmetic" ELSE PRINT "FAIL: Float arithmetic" : FAILED = FAILED + 1

670 REM Test 22: Multiple array dimensions
680 GOSUB 7100
690 IF TESTOK THEN PRINT "PASS: 2D array access" ELSE PRINT "FAIL: 2D array access" : FAILED = FAILED + 1

700 PRINT ""
710 PRINT "===== TEST RESULTS ====="
720 PASSED = 22 - FAILED
730 PRINT "PASSED: "; PASSED
740 PRINT "FAILED: "; FAILED
750 END

5000 REM Test: REM statement (should be ignored)
5010 TESTOK = 1
5020 RETURN

5100 REM Test: GOTO statement
5110 TESTOK = 0
5120 GOTO 5130
5125 TESTOK = 0
5130 TESTOK = 1
5140 RETURN

5200 REM Test: GOSUB and RETURN
5210 TESTOK = 0
5220 GOSUB 5230
5225 RETURN
5230 TESTOK = 1
5235 RETURN

5300 REM Test: IF statement
5310 TESTOK = 0
5320 IF 5 > 3 THEN TESTOK = 1
5330 IF TESTOK <> 1 THEN TESTOK = 0
5340 RETURN

5400 REM Test: String assignment
5410 TESTOK = 0
5420 A$ = "HELLO"
5430 IF A$ = "HELLO" THEN TESTOK = 1
5440 RETURN

5500 REM Test: DIM array
5510 TESTOK = 0
5520 DIM TEST(10)
5530 TEST(5) = 42
5540 IF TEST(5) = 42 THEN TESTOK = 1
5550 RETURN

5600 REM Test: CHR$ function
5610 TESTOK = 0
5620 C$ = CHR$(65)
5630 IF C$ = "A" THEN TESTOK = 1
5640 RETURN

5700 REM Test: STRING$ function
5710 TESTOK = 0
5720 S$ = STRING$(5, "X")
5730 IF LEN(S$) = 5 THEN TESTOK = 1
5740 RETURN

5800 REM Test: MID$ function
5810 TESTOK = 0
5820 T$ = "HELLO"
5830 M$ = MID$(T$, 2, 3)
5840 IF M$ = "ELL" THEN TESTOK = 1
5850 RETURN

5900 REM Test: ASC function
5910 TESTOK = 0
5920 A = ASC("A")
5930 IF A = 65 THEN TESTOK = 1
5940 RETURN

6000 REM Test: VAL function
6010 TESTOK = 0
6020 V = VAL("123")
6030 IF V = 123 THEN TESTOK = 1
6040 RETURN

6100 REM Test: INT function
6110 TESTOK = 0
6120 I = INT(3.7)
6130 IF I = 3 THEN TESTOK = 1
6140 RETURN

6200 REM Test: SPC function
6210 TESTOK = 0
6220 PRINT SPC(5)"TEST"
6230 TESTOK = 1
6240 RETURN

6300 REM Test: STR$ function
6310 TESTOK = 0
6320 N$ = STR$(42)
6330 IF N$ <> "" THEN TESTOK = 1
6340 RETURN

6400 REM Test: FOR/NEXT loops
6410 TESTOK = 0
6420 SUM = 0
6430 FOR I = 1 TO 5
6440 SUM = SUM + I
6450 NEXT I
6460 IF SUM = 15 THEN TESTOK = 1
6470 RETURN

6500 REM Test: PRINT USING
6510 TESTOK = 0
6520 PRINT USING "###.##"; 42.5
6530 TESTOK = 1
6540 RETURN

6600 REM Test: Array indexing (2D simulation)
6610 TESTOK = 0
6620 DIM ARR(10, 2)
6630 ARR(3, 1) = 99
6640 IF ARR(3, 1) = 99 THEN TESTOK = 1
6650 RETURN

6700 REM Test: Comparison operators
6710 TESTOK = 0
6720 IF (5 > 3) AND (2 < 4) THEN TESTOK = 1
6730 IF (10 >= 10) AND (5 <= 5) THEN TESTOK = 1
6740 IF (1 <> 2) THEN TESTOK = 1
6750 RETURN

6800 REM Test: Scientific notation
6810 TESTOK = 0
6820 E = 5.000001E-03
6830 IF E > 0 THEN TESTOK = 1
6840 RETURN

6900 REM Test: Hex numbers
6910 TESTOK = 0
6920 H = &H30
6930 IF H = 48 THEN TESTOK = 1
6940 RETURN

7000 REM Test: Float arithmetic
7010 TESTOK = 0
7020 DEFDBL P
7030 X = 3.14159
7040 Y = X * 2
7050 IF Y > 6 THEN TESTOK = 1
7060 RETURN

7100 REM Test: 2D array arithmetic
7110 TESTOK = 0
7120 DIM AMORT(100, 2)
7130 AMORT(0, 1) = 100000
7140 AMORT(1, 2) = 500
7150 AMORT(1, 1) = AMORT(0, 1) - AMORT(1, 2)
7160 IF AMORT(1, 1) = 99500 THEN TESTOK = 1
7170 RETURN
