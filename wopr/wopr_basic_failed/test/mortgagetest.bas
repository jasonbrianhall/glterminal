1 REM === SIMPLIFIED TEST SUITE FOR MORTGAGE.BAS COMMANDS ===
2 REM Tests individual commands in mortgage.bas with minimal arrays

10 FAILED = 0 : PASSED = 0
20 PRINT "===== MORTGAGE.BAS COMMAND TEST ====="
30 PRINT ""

40 REM Test 1: REM statement
50 GOSUB 1000
60 IF TESTOK THEN PRINT "PASS: REM statement" ELSE PRINT "FAIL: REM" : FAILED = FAILED + 1

70 REM Test 2: GOTO statement
80 GOSUB 1010
90 IF TESTOK THEN PRINT "PASS: GOTO statement" ELSE PRINT "FAIL: GOTO" : FAILED = FAILED + 1

100 REM Test 3: GOSUB and RETURN
110 GOSUB 1020
120 IF TESTOK THEN PRINT "PASS: GOSUB/RETURN" ELSE PRINT "FAIL: GOSUB" : FAILED = FAILED + 1

130 REM Test 4: IF statement
140 GOSUB 1040
150 IF TESTOK THEN PRINT "PASS: IF statement" ELSE PRINT "FAIL: IF" : FAILED = FAILED + 1

160 REM Test 5: String assignment
170 GOSUB 1050
180 IF TESTOK THEN PRINT "PASS: String assignment" ELSE PRINT "FAIL: String" : FAILED = FAILED + 1

190 REM Test 6: DIM single array
200 GOSUB 1060
210 IF TESTOK THEN PRINT "PASS: DIM statement" ELSE PRINT "FAIL: DIM" : FAILED = FAILED + 1

220 REM Test 7: CHR$ function
230 GOSUB 1070
240 IF TESTOK THEN PRINT "PASS: CHR$ function" ELSE PRINT "FAIL: CHR$" : FAILED = FAILED + 1

250 REM Test 8: STRING$ function
260 GOSUB 1080
270 IF TESTOK THEN PRINT "PASS: STRING$ function" ELSE PRINT "FAIL: STRING$" : FAILED = FAILED + 1

280 REM Test 9: MID$ function
290 GOSUB 1090
300 IF TESTOK THEN PRINT "PASS: MID$ function" ELSE PRINT "FAIL: MID$" : FAILED = FAILED + 1

310 REM Test 10: ASC function
320 GOSUB 1100
330 IF TESTOK THEN PRINT "PASS: ASC function" ELSE PRINT "FAIL: ASC" : FAILED = FAILED + 1

340 REM Test 11: VAL function
350 GOSUB 1110
360 IF TESTOK THEN PRINT "PASS: VAL function" ELSE PRINT "FAIL: VAL" : FAILED = FAILED + 1

370 REM Test 12: INT function
380 GOSUB 1120
390 IF TESTOK THEN PRINT "PASS: INT function" ELSE PRINT "FAIL: INT" : FAILED = FAILED + 1

400 REM Test 13: FOR/NEXT loops
410 GOSUB 1130
420 IF TESTOK THEN PRINT "PASS: FOR/NEXT loops" ELSE PRINT "FAIL: FOR/NEXT" : FAILED = FAILED + 1

430 REM Test 14: PRINT USING
440 GOSUB 1145
450 IF TESTOK THEN PRINT "PASS: PRINT USING" ELSE PRINT "FAIL: USING" : FAILED = FAILED + 1

460 REM Test 15: 2D Array indexing
470 GOSUB 1150
480 IF TESTOK THEN PRINT "PASS: 2D Array indexing" ELSE PRINT "FAIL: 2D Array" : FAILED = FAILED + 1

490 REM Test 16: Float arithmetic
500 GOSUB 1160
510 IF TESTOK THEN PRINT "PASS: Float arithmetic" ELSE PRINT "FAIL: Float" : FAILED = FAILED + 1

520 REM Test 17: Scientific notation
530 GOSUB 1170
540 IF TESTOK THEN PRINT "PASS: Scientific notation" ELSE PRINT "FAIL: Sci notation" : FAILED = FAILED + 1

550 REM Test 18: Hex numbers
560 GOSUB 1180
570 IF TESTOK THEN PRINT "PASS: Hex numbers" ELSE PRINT "FAIL: Hex" : FAILED = FAILED + 1

580 REM Test 19: Comparison operators
590 GOSUB 1190
600 IF TESTOK THEN PRINT "PASS: Comparison operators" ELSE PRINT "FAIL: Comparison" : FAILED = FAILED + 1

610 REM Test 20: STR$ function
620 GOSUB 1200
630 IF TESTOK THEN PRINT "PASS: STR$ function" ELSE PRINT "FAIL: STR$" : FAILED = FAILED + 1

640 PRINT ""
650 PRINT "===== TEST RESULTS ====="
660 PASSED = 20 - FAILED
670 PRINT "PASSED: "; PASSED
680 PRINT "FAILED: "; FAILED
690 END

1000 REM Test: REM (ignored by parser)
1001 TESTOK = 1
1002 RETURN

1010 REM Test: GOTO
1011 TESTOK = 0
1012 GOTO 1013
1013 TESTOK = 1
1014 RETURN

1020 REM Test: GOSUB/RETURN
1021 TESTOK = 0
1022 GOSUB 1030
1023 GOTO 1025
1024 TESTOK = 1
1025 RETURN
1030 TESTOK = 1
1031 RETURN

1040 REM Test: IF
1041 TESTOK = 0
1042 IF 5 > 3 THEN TESTOK = 1
1043 RETURN

1050 REM Test: String assignment
1051 TESTOK = 0
1052 A$ = "HELLO"
1053 IF A$ = "HELLO" THEN TESTOK = 1
1054 RETURN

1060 REM Test: DIM
1061 TESTOK = 0
1062 DIM TARR(10, 2)
1063 TARR(2, 1) = 50000
1064 IF TARR(2, 1) = 50000 THEN TESTOK = 1
1065 RETURN

1070 REM Test: CHR$
1071 TESTOK = 0
1072 C$ = CHR$(65)
1073 IF C$ = "A" THEN TESTOK = 1
1074 RETURN

1080 REM Test: STRING$
1081 TESTOK = 0
1082 S$ = STRING$(3, "X")
1083 IF LEN(S$) = 3 THEN TESTOK = 1
1084 RETURN

1090 REM Test: MID$
1091 TESTOK = 0
1092 T$ = "ABCDE"
1093 M$ = MID$(T$, 2, 2)
1094 IF M$ = "BC" THEN TESTOK = 1
1095 RETURN

1100 REM Test: ASC
1101 TESTOK = 0
1102 A = ASC("Z")
1103 IF A = 90 THEN TESTOK = 1
1104 RETURN

1110 REM Test: VAL
1111 TESTOK = 0
1112 V = VAL("456")
1113 IF V = 456 THEN TESTOK = 1
1114 RETURN

1120 REM Test: INT
1121 TESTOK = 0
1122 I = INT(2.9)
1123 IF I = 2 THEN TESTOK = 1
1124 RETURN

1130 REM Test: FOR/NEXT
1131 TESTOK = 0
1132 SUM = 0
1133 FOR I = 1 TO 5
1134 SUM = SUM + I
1135 NEXT I
1136 IF SUM = 15 THEN TESTOK = 1
1137 RETURN

1145 REM Test: PRINT USING
1146 TESTOK = 0
1147 PRINT USING "##.##"; 99.99
1148 TESTOK = 1
1149 RETURN

1150 REM Test: 2D Array
1151 TESTOK = 0
1152 DIM AMORT(10, 2)
1153 AMORT(0, 1) = 100000
1154 AMORT(1, 2) = 400
1155 AMORT(1, 1) = AMORT(0, 1) - 500 + AMORT(1, 2)
1156 IF AMORT(1, 1) = 99900 THEN TESTOK = 1
1157 RETURN

1160 REM Test: Float arithmetic
1161 TESTOK = 0
1162 X = 3.14159
1163 Y = X * 2.5
1164 IF Y > 7.8 THEN TESTOK = 1
1165 RETURN

1170 REM Test: Scientific notation
1171 TESTOK = 0
1172 E = 5.000001E-03
1173 IF E > 0.004 THEN TESTOK = 1
1174 RETURN

1180 REM Test: Hex numbers
1181 TESTOK = 0
1182 H = &H30
1183 IF H = 48 THEN TESTOK = 1
1184 RETURN

1190 REM Test: Comparison operators
1191 TESTOK = 0
1192 IF (5 > 3) AND (2 < 4) AND (7 >= 7) AND (3 <= 5) AND (1 <> 2) THEN TESTOK = 1
1193 RETURN

1200 REM Test: STR$
1201 TESTOK = 0
1202 N$ = STR$(123)
1203 IF N$ <> "" THEN TESTOK = 1
1204 RETURN
